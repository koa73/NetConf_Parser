{
  "vendor": "Arista",
  "version": "1.2",
  "vendor_signatures": [
    "^! Command: show running-config",
    "^! device: [^\\s]+ \\(.*EOS.*\\)$",
    "^boot system flash:"
  ],
  "detect_patterns": [
    "^interface Ethernet",
    "^vlan [0-9]+",
    "^router bgp",
    "^spanning-tree mode"
  ],
  "name_patterns": [
    {"pattern": "^hostname\\s+(\\S+)", "group": 1}
  ],
  "model_patterns": [
    {"pattern": "^! device:\\s+[^\\s]+\\s+\\(([^\\)]+)\\)", "group": 1},
    {"pattern": "^! Model:\\s+(\\S+)", "group": 1},
    {"pattern": "^boot system flash.*?(DCS-\\S+)", "group": 1}
  ],
  "type_inference": [
    {"any": ["router bgp", "router ospf", "ip routing"], "type": "switch", "score": 80},
    {"any": ["interface Vlan", "ip virtual-router"], "type": "switch", "score": 70}
  ],
  "default_device_type": "switch",
  "network_extraction_rules": {
    "interfaces": {
      "start": "^interface\\s+(.+)",
      "ip_pattern": "ip address\\s+(\\S+)\\s+(\\S+)",
      "disable_pattern": "^\\s*shutdown"
    },
    "vlans": {
      "all_pattern": "vlan\\s+(\\d+)",
      "active_pattern": "interface Vlan(\\d+)"
    }
  },

  "lldp_extraction_rules": {
    "enabled": true,
    "lldp_run_pattern": "^lldp run",
    "neighbor_description_pattern": "^\\s+description\\s+(.+)",
    "lldp_agent_pattern": "^\\s+lldp tlv-select",
    "chassis_id_pattern": "lldp tlv-select.*chassis-id",
    "port_id_pattern": "lldp tlv-select.*port-id"
  },

  "interface_status_rules": {
    "enabled": true,
    "shutdown_pattern": "^\\s*shutdown\\s*$",
    "no_shutdown_pattern": "^\\s*no\\s+shutdown\\s*$"
  }
}