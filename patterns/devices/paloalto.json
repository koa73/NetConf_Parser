{
  "vendor": "Palo Alto",
  "version": "1.1",
  "vendor_signatures": [
    "^set deviceconfig system",
    "^set network interface",
    "^# Generated by"
  ],
  "detect_patterns": [
    "^set deviceconfig",
    "^set network",
    "^set rulebase"
  ],
  "name_patterns": [
    {"pattern": "^set deviceconfig system hostname\\s+(\\S+)", "group": 1}
  ],
  "model_patterns": [
    {"pattern": "^# Model:\\s+(\\S+)", "group": 1},
    {"pattern": "^# Device model:\\s+(\\S+)", "group": 1},
    {"pattern": "^set deviceconfig system model (\\S+)", "group": 1}
  ],
  "type_inference": [
    {"any": ["set rulebase security", "set network zone", "set deviceconfig setting management"], "type": "firewall", "score": 100}
  ],
  "default_device_type": "firewall",
  "network_extraction_rules": {
    "interfaces": {
      "start": "^set network interface (?:ethernet|aggregate-group) ([^\\s]+)",
      "ip_pattern": "ip (.+)",
      "disable_pattern": "state no"
    },
    "vlans": {
      "all_pattern": "set network interface vlan vlan(\\d+)",
      "active_pattern": "set network interface vlan vlan(\\d+)"
    }
  },

  "lldp_extraction_rules": {
    "enabled": true,
    "lldp_run_pattern": "^set deviceconfig setting lldp enabled yes",
    "neighbor_description_pattern": "^set network profile lldp.*description\\s+(.+)",
    "lldp_agent_pattern": "^set deviceconfig setting lldp",
    "chassis_id_pattern": "chassis-id",
    "port_id_pattern": "port-id"
  },

  "interface_status_rules": {
    "enabled": true,
    "shutdown_pattern": "state no",
    "no_shutdown_pattern": "state yes"
  }
}